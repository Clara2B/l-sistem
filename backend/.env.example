# Copie este arquivo para .env e preencha os valores

# URL de conexão com o banco PostgreSQL
# Exemplo local:   postgresql://postgres:senha@localhost:5432/lsistem
# Exemplo Render:  postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:senha@localhost:5432/lsistem

# Chave secreta JWT (use uma string longa e aleatória em produção)
JWT_SECRET=troque_por_uma_chave_secreta_longa

# Ambiente: development | production
NODE_ENV=development

# URL do frontend (usado em produção para CORS)
FRONTEND_URL=https://lsistem.vercel.app

# Porta do servidor (opcional, padrão 3001)
PORT=3001
